# JWT secret
JWT_SECRET=your_jwt_secret_here

# Node environment
NODE_ENV=production

# Email settings (unchanged)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS="your_email_app_password"

# Database connection (Aiven MySQL)
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=10969
DB_USER=avnadmin
DB_PASSWORD=YOUR_AIVEN_PASSWORD_HERE   # <-- replace with your actual Aiven password
DB_NAME=defaultdb                 # <-- or 'mydb' if you created/imported a custom DB

# Prisma / Sequelize style URL
DATABASE_URL="mysql://avnadmin:YOUR_AIVEN_PASSWORD_HERE@your-aiven-host.aivencloud.com:10969/defaultdb?sslmode=REQUIRED"

